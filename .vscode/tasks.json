{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "phpcs:lint current file",
            "type": "shell",
            "options": {"cwd": "${workspaceFolder}"},
            "command": ["composer", "run", "lint:file", "${file}"],
            "problemMatcher": []
        }
    ],
}