{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "municipio/backdrop-banner-block",
	"version": "0.1.0",
	"title": "Backdrop Banner",
	"category": "widgets",
	"icon": "cover-image",
	"description": "A backdrop banner block.",
	"example": {},
	"render": "file:./render.php",
	"editorScript": "file:./../../assets/dist/blocks/js/blocks.js",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"anchor": { "type": "string", "default": "" },
		"slides": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"title": { "type": "string" },
					"description": { "type": "string" },
					"url": { "type": "string" },
					"imageId": { "type": "number" },
					"imageUrl": { "type": "string" }
				}
			}
		}
	},
	"textdomain": "municipio"
}
